# ─────────────────────────────────────────────────────────────────────────────
# Root .env — used by docker-compose and all backend services.
# Copy to .env and fill in real values before running `docker-compose up`.
# ─────────────────────────────────────────────────────────────────────────────

# OAuth client credentials (from your 0account app dashboard).
# NEXT_PUBLIC_ prefix makes this available in the browser bundle too (for the
# widget's app-id attribute). The backends receive it as CLIENT_ID via docker-compose.
NEXT_PUBLIC_CLIENT_ID=your-client-id

# IMPORTANT: wrap secrets in single quotes if they contain $ characters
# (e.g. 0account_sec_$argon2id$... format). Docker Compose's env_file parser
# (godotenv) expands unquoted $VAR sequences to empty string, silently
# corrupting the secret. Single quotes prevent this.
CLIENT_SECRET='your-client-secret'

# Auth.js signing secret — generate with: npx auth secret
# Same rule applies: single-quote if the value contains $.
AUTH_SECRET='your-auth-secret'

# Session secret for the Express backend examples
SESSION_SECRET=your-session-secret

# ── Widget flow — register these redirect URIs in your 0account dashboard ────
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Register these callback URIs in your 0account dashboard ──────────────────
# Widget flow:  http://localhost:3000/auth/callback
# OIDC/Auth.js: http://localhost:3000/api/auth/callback/0account
# Passport.js:  http://localhost:8081/auth/callback
# openid-client http://localhost:8082/auth/callback
# go-oidc:      http://localhost:8083/auth/callback
# Goth:         http://localhost:8084/auth/callback

# ── Optional: override public URLs (defaults shown) ──────────────────────────
# APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_PASSPORT_URL=http://localhost:8081
# NEXT_PUBLIC_OPENID_CLIENT_URL=http://localhost:8082
# NEXT_PUBLIC_GO_OIDC_URL=http://localhost:8083
# NEXT_PUBLIC_GO_GOTH_URL=http://localhost:8084
