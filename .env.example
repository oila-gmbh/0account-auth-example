# ─────────────────────────────────────────────────────────────────────────────
# Root .env.example — used by docker-compose.
# Copy to .env and fill in real values before running `docker-compose up`.
#
# NOTE: CLIENT_ID and NEXT_PUBLIC_APP_ID are the same value (your OAuth
# client_id). They are listed separately because CLIENT_ID is server-only
# while NEXT_PUBLIC_APP_ID is inlined into the browser bundle at build time.
# ─────────────────────────────────────────────────────────────────────────────

# OAuth client credentials (from your 0account app dashboard)
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Auth.js signing secret — generate with: npx auth secret
AUTH_SECRET=your-auth-secret

# Public URL of the running showcase (no trailing slash)
APP_URL=http://localhost:3000

# ── Widget flow (NEXT_PUBLIC_* are baked in at build time) ───────────────────
NEXT_PUBLIC_APP_ID=your-client-id
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Required redirect URIs to register in your 0account app dashboard ────────
# Widget flow:  http://localhost:3000/auth/callback       (= NEXT_PUBLIC_REDIRECT_URI above)
# OIDC flow:    http://localhost:3000/api/auth/callback/0account  (Auth.js auto-generated)

SESSION_SECRET=your-session-secret

# Backend service URLs (only needed when running docker-compose with all services)
NEXT_PUBLIC_PASSPORT_URL=http://localhost:8081
NEXT_PUBLIC_OPENID_CLIENT_URL=http://localhost:8082
NEXT_PUBLIC_GO_OIDC_URL=http://localhost:8083
NEXT_PUBLIC_GO_GOTH_URL=http://localhost:8084
