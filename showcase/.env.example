# 0account Auth Example — Showcase

# Required for OIDC flow (Auth.js)
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Generate with: npx auth secret
AUTH_SECRET=your-random-secret

# Required for widget flow
# app-id equals your OAuth client_id
NEXT_PUBLIC_APP_ID=your-client-id

# The redirect_uri registered in your 0account app dashboard.
# For local development: http://localhost:3000/auth/callback
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback

# Used for absolute URLs (optional — defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
